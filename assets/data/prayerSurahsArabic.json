{
  "besmele": "بِسْمِ ٱللّٰهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ",
  "1": {
    "name": "Fatiha",
    "nameAr": "الفاتحة",
    "hasBesmeleAsFirstVerse": true,
    "verses": [
      "بِسْمِ ٱللّٰهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ",
      "ٱلْحَمْدُ لِلّٰهِ رَبِّ ٱلْعَٰلَمِينَ",
      "ٱلرَّحْمَٰنِ ٱلرَّحِيمِ",
      "مَٰلِكِ يَوْمِ ٱلدِّينِ",
      "إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ",
      "ٱهْدِنَا ٱلصِّرَٰطَ ٱلْمُسْتَقِيمَ",
      "صِرَٰطَ ٱلَّذِينَ أَنْعَمْتَ عَلَيْهِمْ غَيْرِ ٱلْمَغْضُوبِ عَلَيْهِمْ وَلَا ٱلضَّالِّينَ"
    ]
  },
  "97": {
    "name": "Kadr",
    "nameAr": "القدر",
    "verses": [
      "إِنَّا أَنْزَلْنَاهُ فِي لَيْلَةِ ٱلْقَدْرِ",
      "وَمَا أَدْرَىٰكَ مَا لَيْلَةُ ٱلْقَدْرِ",
      "لَيْلَةُ ٱلْقَدْرِ خَيْرٌ مِّنْ أَلْفِ شَهْرٍ",
      "تَنَزَّلُ ٱلْمَلَائِكَةُ وَٱلرُّوحُ فِيهَا بِإِذْنِ رَبِّهِمْ مِّنْ كُلِّ أَمْرٍ",
      "سَلَٰمٌ هِيَ حَتَّىٰ مَطْلَعِ ٱلْفَجْرِ"
    ]
  },
  "102": {
    "name": "Tekasur",
    "nameAr": "التكاثر",
    "verses": [
      "أَلْهَىٰكُمُ ٱلتَّكَاثُرُ",
      "حَتَّىٰ زُرْتُمُ ٱلْمَقَابِرَ",
      "كَلَّا سَوْفَ تَعْلَمُونَ",
      "ثُمَّ كَلَّا سَوْفَ تَعْلَمُونَ",
      "كَلَّا لَوْ تَعْلَمُونَ عِلْمَ ٱلْيَقِينِ",
      "لَتَرَوُنَّ ٱلْجَحِيمَ",
      "ثُمَّ لَتَرَوُنَّهَا عَيْنَ ٱلْيَقِينِ",
      "ثُمَّ لَتُسْـَٔلُنَّ يَوْمَئِذٍ عَنِ ٱلنَّعِيمِ"
    ]
  },
  "103": {
    "name": "Asr",
    "nameAr": "العصر",
    "verses": [
      "وَٱلْعَصْرِ",
      "إِنَّ ٱلْإِنسَانَ لَفِي خُسْرٍ",
      "إِلَّا ٱلَّذِينَ ءَامَنُوا وَعَمِلُوا ٱلصَّٰلِحَٰتِ وَتَوَاصَوْا بِٱلْحَقِّ وَتَوَاصَوْا بِٱلصَّبْرِ"
    ]
  },
  "105": {
    "name": "Fil",
    "nameAr": "الفيل",
    "verses": [
      "أَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِأَصْحَٰبِ ٱلْفِيلِ",
      "أَلَمْ يَجْعَلْ كَيْدَهُمْ فِي تَضْلِيلٍ",
      "وَأَرْسَلَ عَلَيْهِمْ طَيْرًا أَبَابِيلَ",
      "تَرْمِيهِم بِحِجَارَةٍ مِّن سِجِّيلٍ",
      "فَجَعَلَهُمْ كَعَصْفٍ مَّأْكُولٍ"
    ]
  },
  "106": {
    "name": "Kureyş",
    "nameAr": "قريش",
    "verses": [
      "لِإِيلَٰفِ قُرَيْشٍ",
      "إِيلَٰفِهِمْ رِحْلَةَ ٱلشِّتَاءِ وَٱلصَّيْفِ",
      "فَلْيَعْبُدُوا رَبَّ هَٰذَا ٱلْبَيْتِ",
      "ٱلَّذِي أَطْعَمَهُم مِّن جُوعٍ وَءَامَنَهُم مِّنْ خَوْفٍ"
    ]
  },
  "107": {
    "name": "Maun",
    "nameAr": "الماعون",
    "verses": [
      "أَرَءَيْتَ ٱلَّذِي يُكَذِّبُ بِٱلدِّينِ",
      "فَذَٰلِكَ ٱلَّذِي يَدُعُّ ٱلْيَتِيمَ",
      "وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ",
      "فَوَيْلٌ لِّلْمُصَلِّينَ",
      "ٱلَّذِينَ هُمْ عَن صَلَاتِهِمْ سَاهُونَ",
      "ٱلَّذِينَ هُمْ يُرَآءُونَ",
      "وَيَمْنَعُونَ ٱلْمَاعُونَ"
    ]
  },
  "108": {
    "name": "Kevser",
    "nameAr": "الكوثر",
    "verses": [
      "إِنَّآ أَعْطَيْنَٰكَ ٱلْكَوْثَرَ",
      "فَصَلِّ لِرَبِّكَ وَٱنْحَرْ",
      "إِنَّ شَانِئَكَ هُوَ ٱلْأَبْتَرُ"
    ]
  },
  "109": {
    "name": "Kafirun",
    "nameAr": "الكافرون",
    "verses": [
      "قُلْ يَٰٓأَيُّهَا ٱلْكَٰفِرُونَ",
      "لَآ أَعْبُدُ مَا تَعْبُدُونَ",
      "وَلَآ أَنتُمْ عَٰبِدُونَ مَآ أَعْبُدُ",
      "وَلَآ أَنَا۠ عَابِدٌ مَّا عَبَدتُّمْ",
      "وَلَآ أَنتُمْ عَٰبِدُونَ مَآ أَعْبُدُ",
      "لَكُمْ دِينُكُمْ وَلِىَ دِينِ"
    ]
  },
  "110": {
    "name": "Nasr",
    "nameAr": "النصر",
    "verses": [
      "إِذَا جَآءَ نَصْرُ ٱللَّهِ وَٱلْفَتْحُ",
      "وَرَأَيْتَ ٱلنَّاسَ يَدْخُلُونَ فِى دِينِ ٱللَّهِ أَفْوَاجًا",
      "فَسَبِّحْ بِحَمْدِ رَبِّكَ وَٱسْتَغْفِرْهُ إِنَّهُۥ كَانَ تَوَّابًا"
    ]
  },
  "111": {
    "name": "Mesed",
    "nameAr": "المسد",
    "verses": [
      "تَبَّتْ يَدَآ أَبِى لَهَبٍ وَتَبَّ",
      "مَآ أَغْنَىٰ عَنْهُ مَالُهُۥ وَمَا كَسَبَ",
      "سَيَصْلَىٰ نَارًا ذَاتَ لَهَبٍ",
      "وَٱمْرَأَتُهُۥ حَمَّالَةَ ٱلْحَطَبِ",
      "فِى جِيدِهَا حَبْلٌ مِّن مَّسَدٍ"
    ]
  },
  "112": {
    "name": "İhlas",
    "nameAr": "الإخلاص",
    "verses": [
      "قُلْ هُوَ ٱللَّهُ أَحَدٌ",
      "ٱللَّهُ ٱلصَّمَدُ",
      "لَمْ يَلِدْ وَلَمْ يُولَدْ",
      "وَلَمْ يَكُن لَّهُۥ كُفُوًا أَحَدٌ"
    ]
  },
  "113": {
    "name": "Felak",
    "nameAr": "الفلق",
    "verses": [
      "قُلْ أَعُوذُ بِرَبِّ ٱلْفَلَقِ",
      "مِن شَرِّ مَا خَلَقَ",
      "وَمِن شَرِّ غَاسِقٍ إِذَا وَقَبَ",
      "وَمِن شَرِّ ٱلنَّفَّٰثَٰتِ فِى ٱلْعُقَدِ",
      "وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ"
    ]
  },
  "114": {
    "name": "Nas",
    "nameAr": "الناس",
    "verses": [
      "قُلْ أَعُوذُ بِرَبِّ ٱلنَّاسِ",
      "مَلِكِ ٱلنَّاسِ",
      "إِلَٰهِ ٱلنَّاسِ",
      "مِن شَرِّ ٱلْوَسْوَاسِ ٱلْخَنَّاسِ",
      "ٱلَّذِى يُوَسْوِسُ فِى صُدُورِ ٱلنَّاسِ",
      "مِنَ ٱلْجِنَّةِ وَٱلنَّاسِ"
    ]
  }
}
