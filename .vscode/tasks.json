{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run app (with version)",
      "type": "shell",
      "command": "dart run scripts/generate_app_version.dart && flutter run",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {}
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
